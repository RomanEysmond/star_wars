<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/characterListFragment">

    <fragment
        android:id="@+id/characterListFragment"
        android:name="com.example.starwars.presentation.ui.characterlist.CharacterListFragment"
        android:label="Star Wars Characters"
        tools:layout="@layout/fragment_character_list">
        <action
            android:id="@+id/action_characterList_to_characterDetail"
            app:destination="@id/characterDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/characterDetailFragment"
        android:name="com.example.starwars.presentation.ui.characterdetail.CharacterDetailFragment"
        android:label="Character Details"
        tools:layout="@layout/fragment_character_detail" />

</navigation>