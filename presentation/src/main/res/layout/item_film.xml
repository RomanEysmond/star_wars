<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/star_wars_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Yellow top stripe -->
        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginBottom="8dp"
            android:background="@color/star_wars_yellow" />

        <!-- Episode Number -->
        <TextView
            android:id="@+id/episodeNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EPISODE IV"
            android:textSize="10sp"
            android:textColor="@color/star_wars_yellow"
            android:fontFamily="monospace"
            android:letterSpacing="0.1" />

        <!-- Film Title -->
        <TextView
            android:id="@+id/filmTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A New Hope"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/star_wars_white"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Director -->
        <TextView
            android:id="@+id/filmDirector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Director: George Lucas"
            android:textSize="12sp"
            android:textColor="@color/star_wars_light_gray"
            android:drawableStart="@android:drawable/ic_menu_edit"
            android:drawablePadding="8dp"
            android:layout_marginBottom="4dp" />

        <!-- Release Date -->
        <TextView
            android:id="@+id/filmReleaseDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1977"
            android:textSize="12sp"
            android:textColor="@color/star_wars_light_gray"
            android:drawableStart="@android:drawable/ic_menu_today"
            android:drawablePadding="8dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>