<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.StarWars" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Основные цвета -->
        <item name="colorPrimary">@color/star_wars_black</item>
        <item name="colorPrimaryVariant">@color/star_wars_dark</item>
        <item name="colorOnPrimary">@color/star_wars_yellow</item>
        <item name="colorSecondary">@color/star_wars_yellow</item>
        <item name="colorSecondaryVariant">@color/star_wars_yellow</item>
        <item name="colorOnSecondary">@color/star_wars_black</item>

        <!-- Статус бар и фон окна -->
        <item name="android:statusBarColor">@color/star_wars_black</item>
        <item name="android:windowBackground">@color/star_wars_black</item>

        <!-- Стиль скроллбара (полосы прокрутки) -->
        <item name="android:scrollbarThumbVertical">@color/star_wars_yellow</item>
        <item name="android:scrollbarSize">4dp</item>
        <item name="android:scrollbarTrackVertical">@color/star_wars_dark</item>
    </style>

</resources>